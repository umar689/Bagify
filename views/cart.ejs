<%- include('./partials/header') %>

<main class="min-h-screen px-5 pt-28 pb-12">
    <section class="site-shell">
        <div class="hero-reveal mb-8 flex flex-col gap-3">
            <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-[#4F8EF7]">Your selection</p>
            <h1 class="section-title text-5xl font-extrabold md:text-6xl">Shopping Cart</h1>
        </div>

        <div class="grid gap-8 lg:grid-cols-[1fr_390px]">
            <% let c=0 %>

            <div class="stagger-group flex flex-col gap-5">
                <% let totalMRP = 0; %>
                <% let totalDiscount = 0; %>

                <% user.cart.forEach(function(product){ %>
                    <% totalMRP += product.product.price*product.quantity %>
                    <% totalDiscount += product.product.discount*product.quantity %>

                    <article class="cart-card premium-card premium-card-hover stagger-item overflow-hidden">
                        <div class="grid md:grid-cols-[220px_1fr]">
                            <div class="cart-image flex h-56 items-center justify-center overflow-hidden bg-gradient-to-br from-[#EEF7FF] to-white p-5">
                                <% if(product.product.image && product.product.image.data){ %>
                                    <img
                                        src="data:<%= product.product.image.contentType %>;base64,<%= product.product.image.data.toString('base64') %>"
                                        class="max-h-full max-w-full object-contain"
                                        alt="<%= product.product.name %>"
                                    >
                                <% } else { %>
                                    <div class="font-semibold text-zinc-400">No Image</div>
                                <% } %>
                            </div>

                            <div class="flex flex-col justify-between p-6 md:p-7">
                                <div>
                                    <h2 class="text-2xl font-extrabold"><%= product.product.name %></h2>

                                    <div class="mt-4 flex flex-wrap items-center gap-3">
                                        <span class="text-3xl font-extrabold text-[#16A34A]">
                                            &#8377; <%= product.product.price - product.product.discount %>
                                        </span>
                                        <span class="font-bold text-zinc-400 line-through">
                                            &#8377; <%= product.product.price %>
                                        </span>
                                        <span class="discount-badge px-3 py-1 text-sm font-extrabold">
                                            Save &#8377; <%= product.product.discount %>
                                        </span>
                                    </div>
                                </div>

                                <div class="mt-8 flex items-center justify-between gap-4">
                                    <div class="flex items-center gap-3 rounded-full bg-white/80 p-2 shadow-sm">
                                        <% if(product.quantity===1){%>
                                            <form action="/cart/delete/<%=product._id%>" method="POST">
                                                <button type="submit" class="icon-pill h-10 w-10 text-lg font-extrabold">-</button>
                                            </form>
                                        <%} else {%>
                                            <form action="/cart/decbyone/<%=product._id%>" method="POST">
                                                <button type="submit" class="icon-pill h-10 w-10 text-lg font-extrabold">-</button>
                                            </form>
                                        <%}%>

                                        <span class="min-w-6 text-center text-lg font-extrabold">
                                            <%=product.quantity%>
                                            <% c+=product.quantity%>
                                        </span>

                                        <form action="/cart/incbyone/<%=product._id%>" method="POST">
                                            <button class="icon-pill h-10 w-10 text-lg font-extrabold">+</button>
                                        </form>
                                    </div>

                                    <form action="/cart/delete/<%=product._id%>" method="POST">
                                        <button type="submit" class="rounded-full px-4 py-2 font-extrabold text-red-500 transition hover:bg-red-50 hover:text-red-600">
                                            Remove
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>

            <aside class="reveal">
                <div class="premium-card sticky top-28 p-7">
                    <div class="mb-6 flex items-center justify-between">
                        <h2 class="text-2xl font-extrabold">Order Summary</h2>
                        <span class="rounded-full bg-[#4F8EF7]/10 px-3 py-1 text-sm font-extrabold text-[#4F8EF7]"><%= c %> items</span>
                    </div>

                    <div class="space-y-4 text-[15px]">
                        <div class="flex justify-between">
                            <span class="muted-text">Total Items</span>
                            <span class="font-extrabold"><%= c %></span>
                        </div>

                        <div class="flex justify-between">
                            <span class="muted-text">Total MRP</span>
                            <span class="font-extrabold">&#8377; <%= totalMRP %></span>
                        </div>

                        <div class="flex justify-between text-[#16A34A]">
                            <span>Total Discount</span>
                            <span class="font-extrabold">- &#8377; <%= totalDiscount %></span>
                        </div>

                        <div class="flex justify-between">
                            <span class="muted-text">Platform Fee</span>
                            <span class="font-extrabold">&#8377; 20</span>
                        </div>

                        <div class="flex justify-between">
                            <span class="muted-text">Shipping</span>
                            <span class="font-extrabold text-[#16A34A]">FREE</span>
                        </div>
                    </div>

                    <div class="my-6 h-px bg-slate-200"></div>

                    <div class="flex items-center justify-between">
                        <h3 class="text-lg font-extrabold">Total Amount</h3>
                        <h3 class="text-3xl font-extrabold text-[#16A34A]">
                            &#8377; <%= (totalMRP - totalDiscount + 20) %>
                        </h3>
                    </div>

                    <button class="premium-btn mt-8 w-full px-6 py-4">
                        Proceed To Checkout
                    </button>
                </div>
            </aside>
        </div>
    </section>
</main>

<%- include('./partials/footer') %>
