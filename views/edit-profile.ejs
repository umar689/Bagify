<%- include('./partials/header') %>

<div class="min-h-screen bg-zinc-100 px-6 md:px-10 pt-28 pb-10">

    <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-sm overflow-hidden">

        <!-- Header -->
        <div class="px-8 py-6 border-b">
            <h1 class="text-4xl font-bold text-zinc-800">
                Edit Profile
            </h1>
            <p class="text-zinc-500 mt-2">
                Update your account information and profile picture
            </p>
        </div>

        <!-- Profile Section -->
        <div class="p-8 border-b">

            <div class="flex flex-col items-center">

                <img 
                    src="data:<%= user.picture.contentType %>;base64,<%= user.picture.data.toString('base64') %>"
                    alt="Profile Picture"
                    class="w-36 h-36 rounded-full object-cover border-4 border-white shadow-lg ring-2 ring-zinc-200"
                />

                <h2 class="mt-4 text-2xl font-semibold text-zinc-800">
                    <%= user.username %>
                </h2>

                <p class="text-zinc-500">
                    <%= user.email %>
                </p>

                <!-- Upload Picture Form -->
                <form
                    action="/upload"
                    method="POST"
                    enctype="multipart/form-data"
                    class="mt-6 flex flex-col sm:flex-row items-center gap-3"
                >

                    <input
                        type="file"
                        name="picture"
                        required
                        class="block w-full text-sm text-zinc-500
                        file:mr-4 file:py-2 file:px-4
                        file:rounded-lg file:border-0
                        file:bg-zinc-100 file:text-zinc-700
                        hover:file:bg-zinc-200"
                    >

                    <button
                        type="submit"
                        class="flex items-center gap-2 px-8 py-1 bg-blue-600 text-white font-medium rounded-xl shadow-md hover:bg-blue-700 hover:shadow-lg transition-all duration-200"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            class="w-5 h-5">
                            <path stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M12 16V4m0 0l-4 4m4-4l4 4M4 16.5v1.5A2 2 0 006 20h12a2 2 0 002-2v-1.5" />
                        </svg>

                        Upload Picture
                    </button>

                </form>

            </div>

        </div>

        <!-- Account Details Form -->
        <div class="p-8">

            <form action="/account/edit" method="POST">

                <div class="space-y-6">

                    <!-- Username -->
                    <div>
                        <label class="block text-sm font-medium text-zinc-700 mb-2">
                            Username
                        </label>

                        <input
                            type="text"
                            name="username"
                            value="<%= user.username %>"
                            minlength="6"
                            required
                            class="w-full px-4 py-3 border border-zinc-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                        >
                    </div>

                    <!-- Email -->
                    <div>
                        <label class="block text-sm font-medium text-zinc-700 mb-2">
                            Email Address
                        </label>

                        <input
                            type="email"
                            value="<%= user.email %>"
                            readonly
                            class="w-full px-4 py-3 border border-zinc-300 rounded-lg bg-zinc-100 cursor-not-allowed"
                        >
                    </div>

                    <!-- Contact -->
                    <div>
                        <label class="block text-sm font-medium text-zinc-700 mb-2">
                            Contact Number
                        </label>

                        <input
                            type="tel"
                            name="contact"
                            value="<%= user.contact || '' %>"
                            placeholder="Enter your contact number"
                            pattern="[6-9][0-9]{9}"
                            maxlength="10"
                            minlength="10"
                            required
                            title="Enter a valid 10-digit mobile number"
                            class="w-full px-4 py-3 border border-zinc-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                        >
                    </div>

                </div>

                <!-- Buttons -->
                <div class="flex flex-wrap gap-4 mt-8">

                    <button
                        type="submit"
                        class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition"
                    >
                        Save Changes
                    </button>

                    <a
                        href="/account"
                        class="px-6 py-3 bg-zinc-200 text-zinc-800 rounded-lg hover:bg-zinc-300 transition"
                    >
                        Cancel
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>