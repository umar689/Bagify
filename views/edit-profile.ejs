<%- include('./partials/header') %>

<main class="min-h-screen px-5 pt-28 pb-12">
    <section class="site-shell max-w-4xl">
        <div class="hero-reveal premium-card overflow-hidden">
            <div class="soft-panel border-b border-white/70 px-8 py-7">
                <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-[#4F8EF7]">Profile settings</p>
                <h1 class="section-title mt-2 text-5xl font-extrabold">Edit Profile</h1>
                <p class="mt-3 muted-text">Update your account information and profile picture</p>
            </div>

            <div class="border-b border-slate-100 p-8">
                <div class="flex flex-col items-center text-center">
                    <img
                        class="profile-image h-32 w-32 rounded-[32px] object-cover shadow-xl ring-4 ring-white"
                        src="<%= user.picture?.data
                            ? `data:${user.picture.contentType};base64,${user.picture.data.toString('base64')}`
                            : '/images/person.png' %>"
                        alt="Profile"
                    />

                    <h2 class="mt-4 text-2xl font-extrabold"><%= user.username %></h2>
                    <p class="muted-text"><%= user.email %></p>

                    <form action="/upload" method="POST" enctype="multipart/form-data" class="mt-6 flex flex-col items-center gap-3 sm:flex-row">
                        <input
                            type="file"
                            name="picture"
                            required
                            class="block w-full text-sm font-semibold text-zinc-500
                            file:mr-4 file:rounded-full file:border-0
                            file:bg-white file:px-5 file:py-3
                            file:font-extrabold file:text-[#4F8EF7]
                            hover:file:bg-blue-50"
                        >

                        <button type="submit" class="premium-btn px-7 py-3">
                            <i class="ri-upload-cloud-line"></i>
                            Upload Picture
                        </button>
                    </form>
                </div>
            </div>

            <div class="p-8">
                <form action="/account/edit" method="POST">
                    <div class="space-y-5">
                        <div>
                            <label class="mb-2 block text-sm font-extrabold muted-text">Username</label>
                            <input type="text" name="username" value="<%= user.username %>" minlength="6" required class="premium-input">
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-extrabold muted-text">Email Address</label>
                            <input type="email" value="<%= user.email %>" readonly class="premium-input cursor-not-allowed bg-slate-100/80">
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-extrabold muted-text">Contact Number</label>
                            <input
                                type="tel"
                                name="contact"
                                value="<%= user.contact || '' %>"
                                placeholder="Enter your contact number"
                                pattern="[6-9][0-9]{9}"
                                maxlength="10"
                                minlength="10"
                                required
                                title="Enter a valid 10-digit mobile number"
                                class="premium-input"
                            >
                        </div>
                    </div>

                    <div class="mt-8 flex flex-wrap gap-4">
                        <button type="submit" class="premium-btn px-7 py-3">
                            Save Changes
                        </button>

                        <a href="/account" class="premium-btn premium-btn-dark px-7 py-3">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </section>
</main>

<%- include('./partials/footer') %>
