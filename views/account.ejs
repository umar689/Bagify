<%- include('./partials/header') %>
<% if(success.length > 0){ %>
    <div id="success-message"
        class="fixed top-[72px] left-1/2 -translate-x-1/2 z-[9999] px-4 py-3 rounded-md bg-blue-500 shadow-lg transition-all duration-500">
        <span class="text-white">
            <%= success[0] %>
        </span>
    </div>

    <script>
        setTimeout(() => {
            const success = document.getElementById("success-message");
            if (success) {
                success.classList.add("opacity-0", "-translate-y-2");
                setTimeout(() => success.remove(), 500);
            }
        }, 5000);
    </script>
<% } %>
<div class="min-h-screen bg-zinc-100 px-10 pt-28 pb-10">

    <div class="max-w-6xl mx-auto">

        <h1 class="text-4xl font-bold mb-8">
            My Account
        </h1>

        <div class="flex gap-8">

            <!-- Profile Card -->
            <div class="w-[30%] bg-white rounded-xl shadow-sm p-6">

                <div class="flex flex-col items-center">

                   <img
                        src="<%= user.picture?.data
                            ? `data:${user.picture.contentType};base64,${user.picture.data.toString('base64')}`
                            : '/images/person.png' %>"
                        alt="Profile"
                    />
                    <h2 class="text-2xl font-semibold mt-4">
                        <%= user.username %>
                    </h2>

                    <p class="text-zinc-500">
                        <%= user.email %>
                    </p>

                </div>

                <div class="mt-8 space-y-4">

                    <div>
                        <p class="text-sm text-zinc-500">Contact</p>
                        <p class="font-medium">
                            <%= user.contact || "Not Added" %>
                        </p>
                    </div>

                    <div>
                        <p class="text-sm text-zinc-500">Member Since</p>
                        <p class="font-medium">
                            <%= user.createdAt.toDateString() %>
                        </p>
                    </div>

                </div>

            </div>

            <!-- Stats & Details -->
            <div class="w-[70%] flex flex-col gap-6">

                <!-- Stats -->
                <div class="grid grid-cols-3 gap-5">

                    <div class="bg-white p-6 rounded-xl shadow-sm">
                        <p class="text-zinc-500">Cart Items</p>
                        <h2 class="text-3xl font-bold mt-2">
                            <% let c = 0; %>
                                <% user.cart.forEach(function(prod){ %>
                                    <% c += prod.quantity; %>
                                <% }) %>
                            <%= c %>
                        </h2>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-sm">
                        <p class="text-zinc-500">Orders</p>
                        <h2 class="text-3xl font-bold mt-2">
                            <%= user.orders.length %>
                        </h2>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-sm">
                        <p class="text-zinc-500">Account Status</p>
                        <h2 class="text-xl font-semibold text-green-600 mt-2">
                            Active
                        </h2>
                    </div>

                </div>

                <!-- User Details -->
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-semibold">
                            Account Information
                        </h2>
                        <a
                            href="/account/edit"
                            class="px-5 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition"
                        >
                            Edit Profile
                        </a>
                    </div>

                    <div class="grid grid-cols-2 gap-6">

                        <div>
                            <label class="block text-zinc-500 mb-2">
                                Username
                            </label>

                            <input
                                type="text"
                                value="<%= user.username %>"
                                readonly
                                class="w-full px-4 py-3 border rounded-lg bg-zinc-100"
                            >
                        </div>

                        <div>
                            <label class="block text-zinc-500 mb-2">
                                Email
                            </label>

                            <input
                                type="text"
                                value="<%= user.email %>"
                                readonly
                                class="w-full px-4 py-3 border rounded-lg bg-zinc-100"
                            >
                        </div>

                        <div>
                            <label class="block text-zinc-500 mb-2">
                                Contact
                            </label>

                            <input
                                type="text"
                                value="<%= user.contact || 'NA' %>"
                                readonly
                                class="w-full px-4 py-3 border rounded-lg bg-zinc-100"
                            >
                        </div>

                    </div>

                </div>
                </div>

            </div>

        </div>

    </div>

</div>