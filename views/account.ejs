<%- include('./partials/header') %>

<% if(success.length > 0){ %>
    <div id="success-message"
        class="fixed top-[88px] left-1/2 z-[9999] -translate-x-1/2 rounded-2xl bg-white/90 px-5 py-3 text-sm font-semibold text-[#4F8EF7] shadow-xl ring-1 ring-blue-100 backdrop-blur-xl transition-all duration-500">
        <%= success[0] %>
    </div>

    <script>
        setTimeout(() => {
            const success = document.getElementById("success-message");
            if (success) {
                success.classList.add("opacity-0", "-translate-y-2");
                setTimeout(() => success.remove(), 500);
            }
        }, 5000);
    </script>
<% } %>

<main class="min-h-screen px-5 pt-28 pb-12">
    <section class="site-shell">
        <div class="hero-reveal mb-8">
            <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-[#4F8EF7]">Profile</p>
            <h1 class="section-title mt-2 text-5xl font-extrabold md:text-6xl">My Account</h1>
        </div>

        <div class="grid gap-8 lg:grid-cols-[340px_1fr]">
            <aside class="reveal premium-card p-7">
                <div class="flex flex-col items-center text-center">
                    <img
                        class="profile-image h-32 w-32 rounded-[32px] object-cover shadow-xl ring-4 ring-white"
                        src="<%= user.picture?.data
                            ? `data:${user.picture.contentType};base64,${user.picture.data.toString('base64')}`
                            : '/images/person.png' %>"
                        alt="Profile"
                    />
                    <h2 class="mt-5 text-2xl font-extrabold"><%= user.username %></h2>
                    <p class="muted-text"><%= user.email %></p>
                </div>

                <div class="mt-8 space-y-5">
                    <div class="rounded-3xl bg-white/70 p-5 shadow-sm">
                        <p class="text-sm font-bold muted-text">Contact</p>
                        <p class="mt-1 font-extrabold"><%= user.contact || "Not Added" %></p>
                    </div>

                    <div class="rounded-3xl bg-white/70 p-5 shadow-sm">
                        <p class="text-sm font-bold muted-text">Member Since</p>
                        <p class="mt-1 font-extrabold"><%= user.createdAt.toDateString() %></p>
                    </div>
                </div>
            </aside>

            <div class="stagger-group flex flex-col gap-6">
                <div class="grid gap-5 md:grid-cols-3">
                    <div class="premium-card stagger-item p-6">
                        <p class="font-bold muted-text">Cart Items</p>
                        <h2 class="mt-2 text-4xl font-extrabold text-[#4F8EF7]">
                            <% let c = 0; %>
                            <% user.cart.forEach(function(prod){ %>
                                <% c += prod.quantity; %>
                            <% }) %>
                            <%= c %>
                        </h2>
                    </div>

                    <div class="premium-card stagger-item p-6">
                        <p class="font-bold muted-text">Orders</p>
                        <h2 class="mt-2 text-4xl font-extrabold text-[#FF8BC2]"><%= user.orders.length %></h2>
                    </div>

                    <div class="premium-card stagger-item p-6">
                        <p class="font-bold muted-text">Account Status</p>
                        <h2 class="mt-3 text-2xl font-extrabold text-[#16A34A]">Active</h2>
                    </div>
                </div>

                <div class="premium-card reveal p-7">
                    <div class="mb-7 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                        <h2 class="text-3xl font-extrabold">Account Information</h2>
                        <a href="/account/edit" class="premium-btn px-6 py-3">
                            <i class="ri-edit-line"></i>
                            Edit Profile
                        </a>
                    </div>

                    <div class="grid gap-5 md:grid-cols-2">
                        <div>
                            <label class="mb-2 block text-sm font-extrabold muted-text">Username</label>
                            <input type="text" value="<%= user.username %>" readonly class="premium-input bg-white/60">
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-extrabold muted-text">Email</label>
                            <input type="text" value="<%= user.email %>" readonly class="premium-input bg-white/60">
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-extrabold muted-text">Contact</label>
                            <input type="text" value="<%= user.contact || 'NA' %>" readonly class="premium-input bg-white/60">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('./partials/footer') %>
