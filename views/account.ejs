<%- include('./partials/header') %>

<div class="min-h-screen bg-zinc-100 px-10 pt-28 pb-10">

    <div class="max-w-6xl mx-auto">

        <h1 class="text-4xl font-bold mb-8">
            My Account
        </h1>

        <div class="flex gap-8">

            <!-- Profile Card -->
            <div class="w-[30%] bg-white rounded-xl shadow-sm p-6">

                <div class="flex flex-col items-center">

                    <img
                        src="<%= user.picture %>"
                        alt="Profile"
                        class="w-32 h-32 rounded-full object-cover border-2 border-zinc-200"
                    >

                    <h2 class="text-2xl font-semibold mt-4">
                        <%= user.username %>
                    </h2>

                    <p class="text-zinc-500">
                        <%= user.email %>
                    </p>

                </div>

                <div class="mt-8 space-y-4">

                    <div>
                        <p class="text-sm text-zinc-500">Contact</p>
                        <p class="font-medium">
                            <%= user.contact || "Not Added" %>
                        </p>
                    </div>

                    <div>
                        <p class="text-sm text-zinc-500">Member Since</p>
                        <p class="font-medium">
                            <%= user.createdAt.toDateString() %>
                        </p>
                    </div>

                </div>

            </div>

            <!-- Stats & Details -->
            <div class="w-[70%] flex flex-col gap-6">

                <!-- Stats -->
                <div class="grid grid-cols-3 gap-5">

                    <div class="bg-white p-6 rounded-xl shadow-sm">
                        <p class="text-zinc-500">Cart Items</p>
                        <h2 class="text-3xl font-bold mt-2">
                            <%= user.cart.length %>
                        </h2>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-sm">
                        <p class="text-zinc-500">Orders</p>
                        <h2 class="text-3xl font-bold mt-2">
                            <%= user.orders.length %>
                        </h2>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-sm">
                        <p class="text-zinc-500">Account Status</p>
                        <h2 class="text-xl font-semibold text-green-600 mt-2">
                            Active
                        </h2>
                    </div>

                </div>

                <!-- User Details -->
                <div class="bg-white rounded-xl shadow-sm p-6">

                    <h2 class="text-2xl font-semibold mb-6">
                        Account Information
                    </h2>

                    <div class="grid grid-cols-2 gap-6">

                        <div>
                            <label class="block text-zinc-500 mb-2">
                                Username
                            </label>

                            <input
                                type="text"
                                value="<%= user.username %>"
                                readonly
                                class="w-full px-4 py-3 border rounded-lg bg-zinc-100"
                            >
                        </div>

                        <div>
                            <label class="block text-zinc-500 mb-2">
                                Email
                            </label>

                            <input
                                type="text"
                                value="<%= user.email %>"
                                readonly
                                class="w-full px-4 py-3 border rounded-lg bg-zinc-100"
                            >
                        </div>

                        <div>
                            <label class="block text-zinc-500 mb-2">
                                Contact
                            </label>

                            <input
                                type="text"
                                value="<%= user.contact || '' %>"
                                readonly
                                class="w-full px-4 py-3 border rounded-lg bg-zinc-100"
                            >
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>