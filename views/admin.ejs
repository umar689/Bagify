<%- include('./partials/header') %>
    <div class="w-full h-screen flex items-start px-20 py-20">
        <div class="w-[25%] flex h-screen flex-col items-start">
            <div class="flex flex-col">
                <a class="block w-fit mb-2" href="/owners/admin">All Products</a>
                <a class="block w-fit mb-2" href="/owners/product/create">Create new product</a>
            </div>
        </div>
        <div class="w-[75%] flex flex-col gap-5 h-screen">
            <a
                href="/owners/product/deleteall"
                onclick="return confirm('⚠️ Are you sure you want to delete all products? This action cannot be undone.')"
                class="w-fit group inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-900 text-red-400 border border-zinc-800 hover:border-red-500 hover:bg-red-500 hover:text-white transition-all duration-300 shadow-sm"
            >
                <i class="ri-delete-bin-6-line group-hover:rotate-12 transition-transform"></i>
                Delete All Products
            </a>
            <div class="flex flex-wrap gap-5">
        <div class="w-[75%] h-screen overflow-y-auto">
            
                    <div class="flex flex-wrap gap-5">

                        <% allproducts.forEach(function(product){ %>

                            <div class="w-60 flex flex-col">

                                <div class="w-full h-52 flex items-center justify-center"
                                    style="background-color:<%= product.bgcolor %>">

                                    <% if(product.image && product.image.data) { %>
                                        <img
                                            class="h-[12rem] object-contain"
                                            src="data:<%= product.image.contentType %>;base64,<%= product.image.data.toString('base64') %>"
                                            alt=""
                                        >
                                    <% } else { %>
                                        <p>No Image</p>
                                    <% } %>

                                </div>

                                <div
                                    class="flex justify-between items-center px-4 py-4 flex-1"
                                    style="background-color:<%= product.panelcolor %>; color:<%= product.textcolor %>">

                                    <div>
                                        <h3 class="font-medium"><%= product.name %></h3>

                                        <% if(product.discount > 0) { %>
                                            <h4>
                                                <del>₹ <%= product.price %></del>
                                            </h4>

                                            <h4>
                                                ₹ <%= product.price - product.discount %>
                                            </h4>
                                        <% } else { %>
                                            <h4>
                                                ₹ <%= product.price %>
                                            </h4>
                                        <% } %>
                                        
                                    </div>
                                        <a
                                            class="w-7 h-7 flex items-center justify-center rounded-full bg-white"
                                            href="/cart/<%= product._id %>">
                                            <i class="ri-subtract-line"></i>
                                        </a>
                                </div>
                                

                            </div>

                        <% }) %>

                    </div>

                </div>

            </div>  
        </div>
    </div>
    <%- include('./partials/footer') %>
   