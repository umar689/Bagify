<%- include('./partials/header') %>

<% if(typeof success !== 'undefined' && success.length>0){ %>
    <div class="fixed top-[88px] left-1/2 z-[9999] -translate-x-1/2 rounded-2xl bg-white/90 px-5 py-3 text-sm font-semibold text-[#4F8EF7] shadow-xl ring-1 ring-blue-100 backdrop-blur-xl">
        <%= success %>
    </div>
<% } %>

<main class="min-h-screen px-5 pt-28 pb-12">
    <section class="site-shell">
        <div class="hero-reveal mb-8">
            <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-[#4F8EF7]">Owner console</p>
            <h1 class="section-title mt-2 text-5xl font-extrabold md:text-6xl">Create New Product</h1>
        </div>

        <div class="grid gap-8 lg:grid-cols-[250px_1fr]">
            <aside class="reveal premium-card h-fit p-6">
                <p class="mb-5 text-sm font-extrabold uppercase tracking-[0.18em] muted-text">Manage</p>
                <div class="flex flex-col gap-3">
                    <a class="soft-link rounded-2xl px-4 py-3 font-bold" href="/owners/admin">All Products</a>
                    <a class="soft-link rounded-2xl px-4 py-3 font-bold" href="/owners/product/create">Create new product</a>
                </div>
            </aside>

            <main class="reveal premium-card p-8">
                <form autocomplete="off" action="/owners/product/create" method="post" enctype="multipart/form-data" class="space-y-8">
                    <section>
                        <div class="mb-5 flex items-center gap-3">
                            <span class="icon-pill h-11 w-11 text-xl text-[#4F8EF7]">
                                <i class="ri-shopping-bag-line"></i>
                            </span>
                            <h2 class="text-2xl font-extrabold">Product Details</h2>
                        </div>

                        <div class="mb-5">
                            <label class="mb-2 block text-sm font-extrabold muted-text">Product Image</label>
                            <input
                                name="image"
                                type="file"
                                value="Select File"
                                class="block w-full text-sm font-semibold text-zinc-500
                                file:mr-4 file:rounded-full file:border-0
                                file:bg-white file:px-5 file:py-3
                                file:font-extrabold file:text-[#4F8EF7]
                                hover:file:bg-blue-50"
                            >
                        </div>

                        <div class="grid gap-4 md:grid-cols-3">
                            <input name="name" type="text" placeholder="Product Name" class="premium-input">
                            <input name="price" type="text" placeholder="Product Price" class="premium-input">
                            <input name="discount" type="text" placeholder="Discount Price" class="premium-input">
                        </div>
                    </section>

                    <section>
                        <div class="mb-5 flex items-center gap-3">
                            <span class="icon-pill h-11 w-11 text-xl text-[#FF8BC2]">
                                <i class="ri-palette-line"></i>
                            </span>
                            <h2 class="text-2xl font-extrabold">Panel Details</h2>
                        </div>

                        <div class="grid gap-4 md:grid-cols-3">
                            <input name="bgcolor" type="text" placeholder="Background Color" class="premium-input">
                            <input name="panelcolor" type="text" placeholder="Panel Color" class="premium-input">
                            <input name="textcolor" type="text" placeholder="Text Color" class="premium-input">
                        </div>
                    </section>

                    <input class="premium-btn cursor-pointer px-7 py-4" type="submit" value="Create New Product">
                </form>
            </main>
        </div>
    </section>
</main>

<%- include('./partials/footer') %>
