<%- include('./partials/header') %>

<% if(success.length > 0){ %>
    <div id="success-message"
        class="fixed top-[88px] left-1/2 z-[9999] -translate-x-1/2 rounded-2xl bg-white/90 px-5 py-3 text-sm font-semibold text-[#4F8EF7] shadow-xl ring-1 ring-blue-100 backdrop-blur-xl transition-all duration-500">
        <%= success[0] %>
    </div>

    <script>
        setTimeout(() => {
            const success = document.getElementById("success-message");
            if (success) {
                success.classList.add("opacity-0", "-translate-y-2");
                setTimeout(() => success.remove(), 500);
            }
        }, 5000);
    </script>
<% } %>

<main class="min-h-screen px-5 pt-28 pb-12">
    <section class="site-shell">
        <div class="hero-reveal premium-card soft-panel mb-8 overflow-hidden p-8 md:p-10">
            <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
                <div>
                    <p class="mb-3 inline-flex rounded-full bg-white/80 px-4 py-2 text-sm font-extrabold text-[#4F8EF7] shadow-sm">
                        Curated carry collection
                    </p>
                    <h1 class="section-title max-w-3xl text-5xl font-extrabold md:text-6xl">Shop bags that move beautifully with your day.</h1>
                </div>

                <form action="<%= currentRoute %>" method="GET" class="flex items-center gap-3 rounded-full border border-white/80 bg-white/80 px-4 py-3 shadow-sm backdrop-blur-xl">
                    <label class="text-sm font-extrabold muted-text">Sort</label>
                    <select class="bg-transparent text-sm font-bold text-[#1F2937] outline-none" name="sortby" onchange="this.form.submit()">
                        <option value="popular" <%= sortby === 'popular' ? 'selected' : '' %>>Popular</option>
                        <option value="newest" <%= sortby === 'newest' ? 'selected' : '' %>>Newest</option>
                    </select>
                </form>
            </div>
        </div>

        <div class="grid gap-8 lg:grid-cols-[250px_1fr]">
            <aside class="reveal premium-card h-fit p-6">
                <p class="mb-5 text-sm font-extrabold uppercase tracking-[0.18em] text-[#6B7280]">Browse</p>
                <div class="flex flex-col gap-3">
                    <a class="soft-link rounded-2xl px-4 py-3 font-bold" href="/shop/new">New Collection</a>
                    <a class="soft-link rounded-2xl px-4 py-3 font-bold" href="/shop">All Products</a>
                    <a class="soft-link rounded-2xl px-4 py-3 font-bold" href="/shop/discounted">Discounted Products</a>
                </div>
            </aside>

            <div class="stagger-group grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
                <% products.forEach(function(product){ %>
                    <article class="product-card premium-card premium-card-hover stagger-item flex flex-col p-4">
                        <div class="product-media flex items-center justify-center p-6"
                            style="background-color:<%= product.bgcolor %>">
                            <% if(product.image && product.image.data) { %>
                                <img
                                    class="h-56 max-w-full object-contain"
                                    src="data:<%= product.image.contentType %>;base64,<%= product.image.data.toString('base64') %>"
                                    alt="<%= product.name %>"
                                >
                            <% } else { %>
                                <p class="font-semibold muted-text">No Image</p>
                            <% } %>
                        </div>

                        <div class="flex flex-1 items-center justify-between gap-4 px-2 py-5">
                            <div>
                                <h3 class="text-lg font-extrabold"><%= product.name %></h3>
                                <% if(product.discount > 0) { %>
                                    <div class="mt-2 flex flex-wrap items-center gap-2">
                                        <span class="text-xl font-extrabold text-[#1F2937]">&#8377; <%= product.price - product.discount %></span>
                                        <del class="text-sm font-bold text-slate-400">&#8377; <%= product.price %></del>
                                        <span class="discount-badge px-3 py-1 text-xs font-extrabold">Save &#8377; <%= product.discount %></span>
                                    </div>
                                <% } else { %>
                                    <p class="mt-2 text-xl font-extrabold text-[#1F2937]">&#8377; <%= product.price %></p>
                                <% } %>
                            </div>

                            <a class="icon-pill h-12 w-12 shrink-0 text-xl" href="/cart/<%= product._id %>" aria-label="Add <%= product.name %> to cart">
                                <i class="ri-add-line"></i>
                            </a>
                        </div>
                    </article>
                <% }) %>
            </div>
        </div>
    </section>
</main>

<%- include('./partials/footer') %>
