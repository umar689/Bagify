<%- include('./partials/header') %>
    <div class="w-full h-screen flex px-20">
    <div class="w-1/2 flex items-center justify-center h-screen">
        <div class="w-full max-w-md px-10">

            <h4 class="text-3xl font-semibold mb-2">Admin Access</h4>
            <p class="text-zinc-500 mb-6">Sign in to manage your store.</p>

            <form action="/owners/login" method="post">

                <input
                    class="block bg-zinc-100 w-full px-4 py-3 border rounded-lg mb-4 border-zinc-200 focus:outline-none focus:ring-2 focus:ring-blue-500"
                    type="email"
                    placeholder="Email"
                    name="email">

                <input
                    class="block bg-zinc-100 w-full px-4 py-3 border rounded-lg mb-4 border-zinc-200 focus:outline-none focus:ring-2 focus:ring-blue-500"
                    type="password"
                    placeholder="Password"
                    name="password">

                <input
                    class="w-full py-3 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 transition"
                    type="submit"
                    value="Login">
            </form>

            <!-- Divider -->
            <div class="flex items-center my-8">
                <div class="flex-1 h-px bg-zinc-300"></div>
                <span class="px-4 text-sm text-zinc-500">OR</span>
                <div class="flex-1 h-px bg-zinc-300"></div>
            </div>

            <!-- Buyer Login -->
            <a
    href="/"
    class="mt-6 flex w-full items-center justify-center gap-2 rounded-xl bg-zinc-900 px-5 py-3 text-white font-medium transition-all duration-300 hover:bg-zinc-800 hover:shadow-lg"
>
    <i class="ri-shopping-bag-3-line text-lg"></i>
    Login as Buyer
</a>

        </div>
    </div>
</div>
    <%- include('./partials/footer') %>