<%- include('./partials/header') %>

<main class="min-h-screen px-5 pt-28 pb-12">
    <section class="site-shell grid min-h-[calc(100vh-8rem)] items-center gap-8 lg:grid-cols-[1fr_0.9fr]" data-parallax>
        <div class="hero-reveal">
            <p class="mb-4 inline-flex rounded-full bg-white/80 px-4 py-2 text-sm font-extrabold text-[#4F8EF7] shadow-sm">
                Bagify owner console
            </p>
            <h1 class="section-title max-w-2xl text-6xl font-extrabold">Manage the store with clarity.</h1>
            <p class="mt-5 max-w-lg text-lg leading-8 muted-text">
                A softer, cleaner workspace for keeping the collection polished.
            </p>
        </div>

        <div class="hero-reveal premium-card p-8" data-depth="10">
            <div class="mb-7">
                <span class="icon-pill mb-4 h-12 w-12 text-xl text-[#4F8EF7]">
                    <i class="ri-shield-user-line"></i>
                </span>
                <h2 class="text-3xl font-extrabold">Admin Access</h2>
                <p class="mt-2 muted-text">Sign in to manage your store.</p>
            </div>

            <form action="/owners/login" method="post" class="space-y-4">
                <input class="premium-input" type="email" placeholder="Email" name="email">
                <input class="premium-input" type="password" placeholder="Password" name="password">
                <input class="premium-btn w-full cursor-pointer px-6 py-4" type="submit" value="Login">
            </form>

            <div class="my-8 flex items-center">
                <div class="h-px flex-1 bg-slate-200"></div>
                <span class="px-4 text-sm font-bold muted-text">OR</span>
                <div class="h-px flex-1 bg-slate-200"></div>
            </div>

            <a href="/" class="premium-btn premium-btn-dark w-full px-6 py-4">
                <i class="ri-shopping-bag-3-line text-lg"></i>
                Login as Buyer
            </a>
        </div>
    </section>
</main>

<%- include('./partials/footer') %>
